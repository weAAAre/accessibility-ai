{
  "name": "@weaaare/mcp-a11y-readability",
  "version": "0.1.1",
  "description": "MCP server for text readability analysis — Spanish and English readability formulas, WCAG 3.1.5 compliance, and plain language assessment",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-a11y-readability": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "check-types": "tsc --noEmit",
    "lint": "biome check .",
    "dev": "tsc --watch",
    "test": "rstest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "catalog:",
    "silabajs": "catalog:",
    "syllable": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@rstest/core": "catalog:",
    "@types/node": "catalog:",
    "@weaaare/config": "workspace:*",
    "typescript": "catalog:"
  },
  "keywords": [
    "mcp",
    "accessibility",
    "a11y",
    "readability",
    "wcag",
    "plain-language",
    "flesch",
    "fernandez-huerta",
    "inflesz",
    "legibilidad"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/weAAAre/a11y-agents-kit.git",
    "directory": "packages/mcp-a11y-readability"
  },
  "homepage": "https://github.com/weAAAre/a11y-agents-kit/tree/main/packages/mcp-a11y-readability#readme",
  "bugs": {
    "url": "https://github.com/weAAAre/a11y-agents-kit/issues"
  },
  "author": "weAAAre <hola@weAAAre.com> (https://weAAAre.com)",
  "engines": {
    "node": ">=24"
  }
}
