    "directory": "packages/mcp-a11y-color"
  },
  "homepage": "https://github.com/weAAAre/accessibility-skills/tree/main/packages/mcp-a11y-color#readme",
  "bugs": {
    "url": "https://github.com/weAAAre/accessibility-skills/issues"
