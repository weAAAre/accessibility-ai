  "description": "MCP server for color accessibility — contrast checking, color blindness simulation, palette analysis, and WCAG 2.2 compliance",
  "license": "MIT",
  "type": "module",
  "bin": {
    "mcp-a11y-color": "dist/index.js"
  },
  "main": "dist/index.js",
